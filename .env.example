# LINE LIFF app ID, for example 1234567890-AbCdEfGh
LINE_LIFF_ID=

# Messaging API channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=

# Messaging API channel secret, used to verify X-Line-Signature
LINE_CHANNEL_SECRET=

# Optional: userId, groupId, or roomId to receive daily task summaries
LINE_TARGET_ID=

# Optional: use Supabase as the real production database.
# Keep the service role key only on the backend/deploy service, never in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public HTTPS URL of the deployed app, for LINE cards and LIFF links.
PUBLIC_BASE_URL=
